# ── RabbitMQ ────────────────────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=lms_user
RABBITMQ_DEFAULT_PASS=change_me_strong_password
RABBITMQ_DEFAULT_VHOST=lms

# Memory high-watermark: fraction of total RAM before flow control kicks in
RABBITMQ_VM_MEMORY_HIGH_WATERMARK=0.6

# Disk free limit: pause publishing when free disk drops below this value
RABBITMQ_DISK_FREE_LIMIT=2GB

# ── Grafana ─────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# ── Ports (host-side bindings) ───────────────────────────────────────────────
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MGMT_PORT=15672
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
NODE_EXPORTER_PORT=9100
